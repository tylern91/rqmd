#!/usr/bin/env bash
# pre-push hook: blocks v* tag pushes unless the crate version and CHANGELOG
# are consistent. Install via: skills/release/scripts/install-hooks.sh
set -euo pipefail

while read -r local_ref local_sha remote_ref remote_sha; do
  # Only gate on tag pushes matching v*
  if [[ "$local_ref" != refs/tags/v* ]]; then
    continue
  fi

  TAG="${local_ref#refs/tags/}"
  VERSION="${TAG#v}"

  # 1. Check that all crate versions match the tag
  for f in crates/*/Cargo.toml; do
    CRATE_VERSION=$(grep '^version = ' "$f" | head -1 | sed 's/version = "//;s/"//')
    if [[ "$CRATE_VERSION" != "$VERSION" ]]; then
      echo "ERROR: $f version '$CRATE_VERSION' does not match tag '$TAG'" >&2
      exit 1
    fi
  done

  # 2. Check that CHANGELOG.md has a [X.Y.Z] entry
  if ! grep -qE "^\#\# \[$VERSION\]" CHANGELOG.md; then
    echo "ERROR: CHANGELOG.md has no '## [$VERSION]' entry" >&2
    exit 1
  fi

  echo "pre-push: version and changelog checks passed for $TAG"
done

exit 0
